{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "paths": {
      "@repo/types": ["../../packages/types/src/index.ts"],
      "@repo/utils": ["../../packages/utils/src/index.ts"],
      "@repo/validators": ["../../packages/validators/src/index.ts"],
      "@repo/db": ["../../packages/db/src/index.ts"],
      "@repo/auth": ["../../packages/auth/src/index.ts"],
      "@repo/auth/client": ["../../packages/auth/src/client.ts"],
      "@repo/api": ["../../packages/api/src/index.ts"],
      "@repo/inngest": ["../../packages/inngest/src/index.ts"],
      "@repo/ai": ["../../packages/ai/src/index.ts"],
      "@repo/github": ["../../packages/github/src/index.ts"],
      "@repo/billing": ["../../packages/billing/src/index.ts"],
      "@repo/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
